<DefaultWindow xmlns="https://spacestation14.io"
               xmlns:cc="clr-namespace:Content.Client.Administration.UI.CustomControls"
               Title="{Loc admin-screen-check-window-title}"
               MinSize="420 500">
    <BoxContainer Orientation="Vertical" SeparationOverride="4">
        <Label Name="SelectedPlayerLabel" Text="{Loc admin-screen-check-window-no-player}" />
        <cc:PlayerListControl Name="PlayerList" VerticalExpand="True"/>
        <BoxContainer Orientation="Horizontal" SeparationOverride="4">
            <Button Name="OpenPlayerPanelButton"
                    HorizontalExpand="True"
                    Disabled="True"
                    Text="{Loc admin-screen-check-window-open-player-panel}" />
            <Button Name="RequestScreenCheckButton"
                    HorizontalExpand="True"
                    Disabled="True"
                    Text="{Loc admin-screen-check-window-run}" />
        </BoxContainer>
        <Label Name="HintLabel" ClipText="True" />
    </BoxContainer>
</DefaultWindow>
